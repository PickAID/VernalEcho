[run]
# Optional.
# Format: "PlayerName" or "PlayerName,uuid-without-dashes"
mc_user = "DevPlayer,00000000000000000000000000000001"

[build]
# Optional local toggle for the legacy formal-version increment flow.
formal_version = false

[publish]
